package web

// sourceText is the mandatory escaped-text boundary for untrusted web content.
templ sourceText(content string) {
	{ content }
}

templ indexPage() {
	<!DOCTYPE html>
	<html lang="en">
		<head>
			<meta charset="utf-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1"/>
			<title>AgentSession</title>
			<link rel="stylesheet" href="/assets/styles.css"/>
		</head>
		<body>
			<main>
				<p class="eyebrow">Local-first session evidence</p>
				<h1>AgentSession</h1>
				<p class="lede">Understand what your coding agent actually did.</p>
				<section aria-labelledby="empty-title">
					<h2 id="empty-title">No sessions indexed yet</h2>
					<p>Discovery and importing are coming next. AgentSession will keep source sessions read-only and analysis on this machine.</p>
				</section>
			</main>
		</body>
	</html>
}
